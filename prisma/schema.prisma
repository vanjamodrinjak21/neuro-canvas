// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  output          = "../server/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// Auth.js required models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  bio           String?   @db.VarChar(280)
  password      String? // For credentials auth (hashed)

  // Security
  passwordChangedAt   DateTime?
  totpSecret          String? // Encrypted TOTP secret
  totpEnabled         Boolean   @default(false)
  backupCodes         String[]  @default([]) // Hashed backup codes
  lastTotpDelta       Int? // Replay protection: last accepted TOTP delta
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  accounts    Account[]
  sessions    Session[]
  credentials Credential[]
  maps        Map[]
  templates   Template[]
  syncState   SyncState?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Sync & Map Storage ────────────────────────────────────────────

model Map {
  id          String          @id // Client-generated CUID
  userId      String
  title       String
  data        Json // { nodes, edges, camera, settings, rootNodeId }
  checksum    String // SHA-256 for integrity + quick diff
  preview     String?         @db.Text // Base64 thumbnail
  syncVersion Int             @default(1) // Optimistic concurrency
  byteSize    Int             @default(0)
  tags        String[]        @default([])
  ydoc        Bytes? // Yjs binary state — source of truth once realtime collab ships
  ydocVersion Int             @default(0) // Monotonic, bumped on every flush
  deletedAt   DateTime? // Soft-delete for cross-device propagation
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions    MapVersion[]
  embeddings  NodeEmbedding[]
  shares      MapShare[]

  @@index([userId, updatedAt])
  @@index([userId])
}

model MapVersion {
  id         String   @id @default(cuid())
  mapId      String
  version    Int
  data       Json
  checksum   String
  deviceId   String?
  byteSize   Int      @default(0)
  ydocBinary Bytes? // Snapshot of Y.Doc at this checkpoint, for time-travel
  authorId   String? // User who triggered this checkpoint
  createdAt  DateTime @default(now())
  map        Map      @relation(fields: [mapId], references: [id], onDelete: Cascade)

  @@unique([mapId, version])
  @@index([mapId])
}

model SyncState {
  id            String   @id @default(cuid())
  userId        String   @unique
  lastSyncAt    DateTime @default(now())
  lastDeviceId  String?
  totalMaps     Int      @default(0)
  totalByteSize BigInt   @default(0)
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Share Links ──────────────────────────────────────────────────

enum ShareRole {
  VIEWER
  EDITOR
}

model MapShare {
  id         String    @id @default(cuid())
  mapId      String
  token      String    @unique
  createdBy  String
  role       ShareRole @default(VIEWER)
  label      String?
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?
  revokedAt  DateTime? // Soft-revoke; broadcasts kick to room
  lastUsedAt DateTime? // For "X joined this week" stats
  map        Map       @relation(fields: [mapId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([mapId])
}

model CollabSession {
  id       String    @id @default(cuid())
  mapId    String
  userId   String // "guest:<nanoid>" for anonymous viewers
  shareId  String?
  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  @@index([mapId])
  @@index([userId])
}

// ─── Credential Vault ──────────────────────────────────────────────

model Credential {
  id                String    @id @default(cuid())
  userId            String
  provider          String // 'openai', 'anthropic', 'openrouter', 'custom'
  label             String?
  encryptedValue    String    @db.Text // Double-encrypted: client AES-GCM + server AES-256-GCM
  keyHash           String // HMAC of first 8 chars for identification
  encryptionVersion Int       @default(1) // 1=legacy, 2=KEK, 3=rotated AUTH_SECRET
  lastUsed          DateTime?
  expiresAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, label])
  @@index([userId])
}

// ─── Templates ──────────────────────────────────────────────────

model Template {
  id          String           @id @default(cuid())
  slug        String           @unique
  title       String
  description String?          @db.Text
  category    TemplateCategory
  tags        String[]         @default([])
  nodes       Json // Serialized node map
  edges       Json // Serialized edge map
  settings    Json? // Map settings (grid, colors, etc.)
  nodeCount   Int              @default(0)
  levelCount  Int              @default(0)
  previewData Json? // CSS preview shape/color data
  aiEnhanced  Boolean          @default(false)
  isSystem    Boolean          @default(false)
  isPublic    Boolean          @default(true)
  usageCount  Int              @default(0)
  authorId    String?
  author      User?            @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([category])
  @@index([authorId])
  @@index([isPublic, category])
  @@index([slug])
}

// ─── Vector Embeddings ──────────────────────────────────────────

model NodeEmbedding {
  id           String                     @id @default(cuid())
  mapId        String
  nodeId       String
  embedding    Unsupported("vector(256)")
  contentHash  String
  modelVersion String                     @default("nomic-embed-text-v1.5")
  dimensions   Int                        @default(256)
  sourceText   String                     @db.Text
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  map          Map                        @relation(fields: [mapId], references: [id], onDelete: Cascade)

  @@unique([mapId, nodeId])
  @@index([mapId])
}

enum TemplateCategory {
  education
  business
  creative
  planning
  research
}
