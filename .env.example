# Database
DATABASE_URL="postgresql://user:password@host:port/database"

# Redis (caching)
REDIS_URL="redis://default:password@host:port"

# Auth.js
AUTH_SECRET="your-256-bit-secret"
AUTH_ORIGIN="http://localhost:3000"

# OAuth - Google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OAuth - GitHub
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="NeuroCanvas <noreply@neurocanvas.app>"

# Real-time collab (Phase 2 turns this on; Phase 1 leaves NUXT_PUBLIC_COLLAB_ENABLED=false)
NUXT_PUBLIC_COLLAB_ENABLED="false"
PARTYKIT_FLUSH_SECRET=""
