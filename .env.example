# Database
DATABASE_URL="postgresql://user:password@host:port/database"

# Redis (caching)
REDIS_URL="redis://default:password@host:port"

# Auth.js
AUTH_SECRET="your-256-bit-secret"
AUTH_ORIGIN="http://localhost:3000"

# OAuth - Google (web)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OAuth - Google (desktop / Tauri) — separate Web-application OAuth client
# with http://localhost added under Authorized redirect URIs.
# Token exchange runs server-side; secret is never bundled in the client app.
GOOGLE_DESKTOP_CLIENT_ID=""
GOOGLE_DESKTOP_CLIENT_SECRET=""

# OAuth - Google (Android) — registered with package com.neurocanvas.app
# and the keystore SHA-1 fingerprint. Used by the native Google Sign-In flow.
NUXT_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=""

# OAuth - GitHub
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="NeuroCanvas <noreply@neurocanvas.app>"

# Real-time collab (Phase 2 turns this on; Phase 1 leaves NUXT_PUBLIC_COLLAB_ENABLED=false)
NUXT_PUBLIC_COLLAB_ENABLED="false"
PARTYKIT_FLUSH_SECRET=""
PARTYKIT_JWT_SECRET=""
NUXT_PUBLIC_PARTYKIT_HOST=""    # e.g. nc-collab.your-name.partykit.dev

# Releases proxy (powers /download page)
# Format: "owner/name" — e.g. "neurocanvas/neurocanvas"
GITHUB_RELEASES_REPO=""
# Optional — lifts the unauth 60-req/hr GitHub API rate limit to 5000
# (read-only public_repo scope is enough; no need for write perms here)
GITHUB_TOKEN=""
# Optional — public-side hint so the page can show a GitHub link before the
# /api/releases/latest response lands. Safe to expose.
NUXT_PUBLIC_RELEASES_REPO=""

# Auth callbacks debug logging (verbose; off by default)
AUTH_DEBUG="false"
