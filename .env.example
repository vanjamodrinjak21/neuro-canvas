# Database
DATABASE_URL="postgresql://user:password@host:port/database"

# Redis (caching)
REDIS_URL="redis://default:password@host:port"

# Auth.js
AUTH_SECRET="your-256-bit-secret"
AUTH_ORIGIN="http://localhost:3000"

# OAuth - Google (web)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OAuth - Google (desktop / Tauri) — separate Web-application OAuth client
# with http://localhost added under Authorized redirect URIs.
# Token exchange runs server-side; secret is never bundled in the client app.
GOOGLE_DESKTOP_CLIENT_ID=""
GOOGLE_DESKTOP_CLIENT_SECRET=""

# OAuth - Google (Android) — registered with package com.neurocanvas.app
# and the keystore SHA-1 fingerprint. Server-only: used as an allowed
# audience when validating ID tokens the native shell sends to
# /api/auth/desktop-google. The Android app itself reads its client ID
# from google-services.json at build time, not from runtime config.
GOOGLE_ANDROID_CLIENT_ID=""
GOOGLE_IOS_CLIENT_ID=""

# OAuth - GitHub
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="NeuroCanvas <noreply@neurocanvas.app>"

# Real-time collab (Phase 2 turns this on; Phase 1 leaves NUXT_PUBLIC_COLLAB_ENABLED=false)
NUXT_PUBLIC_COLLAB_ENABLED="false"
PARTYKIT_FLUSH_SECRET=""
PARTYKIT_JWT_SECRET=""
NUXT_PUBLIC_PARTYKIT_HOST=""    # e.g. nc-collab.your-name.partykit.dev

# Releases proxy (powers /download page)
# Format: "owner/name" — e.g. "vanjamodrinjak21/neuro-canvas".
# A full GitHub URL is also accepted; the server extracts owner/name from it.
GITHUB_RELEASES_REPO=""

# Rolling-channel tag the /api/releases/latest endpoint fetches deterministically.
# Default is "beta" (matches the current unsigned-build channel). Set to "stable"
# once we ship signed builds and switch to per-version tags + R2 paths.
RELEASES_CHANNEL="beta"
# Optional — lifts the unauth 60-req/hr GitHub API rate limit to 5000
# (read-only public_repo scope is enough; no need for write perms here)
GITHUB_TOKEN=""
# Optional — public-side hint so the page can show a GitHub link before the
# /api/releases/latest response lands. Safe to expose.
NUXT_PUBLIC_RELEASES_REPO=""

# Cloudflare R2 CDN — /download rewrites every GitHub asset URL to point at
# this host (pattern: {CDN_BASE_URL}/v{tag}/<filename>). Leave empty to
# fall back to direct GitHub release URLs.
CDN_BASE_URL="https://cdn.neuro-canvas.com"
NUXT_PUBLIC_CDN_BASE_URL="https://cdn.neuro-canvas.com"

# R2 credentials — only needed for the GitHub Actions release workflow that
# uploads built binaries to R2. Add these as GitHub repo secrets, NOT to
# Railway (the running server doesn't write to R2 — only CI does).
# Generate via Cloudflare dashboard → R2 → Manage R2 API Tokens.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="neurocanvas-releases"

# Auth callbacks debug logging (verbose; off by default)
AUTH_DEBUG="false"
