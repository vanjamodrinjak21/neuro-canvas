{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "fs:default",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOWNLOAD/**" }
      ]
    },
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-exists",
    "fs:allow-remove",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "shell:default",
    "shell:allow-open",
    "process:default",
    "os:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://api.openai.com/**" },
        { "url": "https://api.anthropic.com/**" },
        { "url": "https://openrouter.ai/**" },
        { "url": "http://localhost:**" },
        { "url": "http://127.0.0.1:**" },
        { "url": "https://*" }
      ]
    }
  ]
}
